{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brettreynolds.ca/schemas/delegation/program-specifications-1.0.0.json",
  "title": "Delegation Assurance empirical programme specifications",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "frozen_at", "specifications"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "revised_at": {"type": "string", "format": "date-time"},
    "design_analysis": {"type": "string", "minLength": 1},
    "specifications": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/specification"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"},
    "idList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "uncertainty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "report"],
      "properties": {
        "method": {
          "enum": [
            "partial_pooling_family_effect_interval",
            "trace_family_cluster_interval_t_or_multilevel",
            "crossed_reviewer_case_variance"
          ]
        },
        "report": {"const": "estimate_and_interval"},
        "confidence_level": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        }
      }
    },
    "designFloors": {
      "type": "object",
      "additionalProperties": false,
      "required": ["advisory"],
      "properties": {
        "advisory": {"const": true},
        "minimum_observations_per_family": {"type": "integer", "minimum": 2},
        "minimum_trace_families_per_family": {"type": "integer", "minimum": 2},
        "minimum_cases_per_family": {"type": "integer", "minimum": 2},
        "minimum_reviewers_per_family": {"type": "integer", "minimum": 2},
        "minimum_control_accuracy": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "specification_id",
        "specification_version",
        "claim_id",
        "status",
        "input_schema",
        "required_families",
        "primary_estimand",
        "uncertainty",
        "design_floors",
        "integrity_rules",
        "aggregation_rule"
      ],
      "properties": {
        "program_id": {
          "enum": ["local_discrimination", "predictive_typed_ablation", "reviewer_reconstruction"]
        },
        "specification_id": {"$ref": "#/$defs/id"},
        "specification_version": {"const": "1.0.0"},
        "claim_id": {"enum": ["DA_LOCAL_001", "DA_PRED_001", "DA_RECON_001"]},
        "status": {"const": "frozen_before_target_outcomes"},
        "input_schema": {"type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$"},
        "required_families": {"$ref": "#/$defs/idList"},
        "primary_estimand": {"type": "string", "minLength": 1},
        "uncertainty": {"$ref": "#/$defs/uncertainty"},
        "design_floors": {"$ref": "#/$defs/designFloors"},
        "integrity_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reset_policy", "split_policy", "banned_view_key_tokens", "reference_join_policy", "required_design_object_bindings"],
          "properties": {
            "reset_policy": {"enum": ["reset_before_each_presentation", "independent_randomized_presentation"]},
            "split_policy": {"enum": ["held_out_base_items", "disjoint_trace_families", "held_out_cases_balanced_across_arms"]},
            "banned_view_key_tokens": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "reference_join_policy": {"enum": ["after_response_lock", "after_prediction_lock", "after_review_lock"]},
            "required_design_object_bindings": {"$ref": "#/$defs/idList"},
            "feature_allowlist": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/id"}
            },
            "matched_case_coverage_required": {"type": "boolean"}
          }
        },
        "aggregation_rule": {"const": "familywise_noncompensatory_vector"}
      }
    }
  }
}
