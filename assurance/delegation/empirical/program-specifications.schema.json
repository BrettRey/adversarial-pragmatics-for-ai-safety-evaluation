{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brettreynolds.ca/schemas/delegation/program-specifications-1.0.0.json",
  "title": "Frozen Delegation Assurance empirical programme specifications",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "frozen_at", "specifications"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "specifications": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"$ref": "#/$defs/specification"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"},
    "idList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    },
    "specification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "program_id",
        "specification_id",
        "specification_version",
        "claim_id",
        "status",
        "input_schema",
        "required_families",
        "primary_estimand",
        "uncertainty",
        "thresholds",
        "integrity_rules",
        "aggregation_rule"
      ],
      "properties": {
        "program_id": {
          "enum": ["local_discrimination", "predictive_typed_ablation", "reviewer_reconstruction"]
        },
        "specification_id": {"$ref": "#/$defs/id"},
        "specification_version": {"const": "1.0.0"},
        "claim_id": {"enum": ["DA_LOCAL_001", "DA_PRED_001", "DA_RECON_001"]},
        "status": {"const": "frozen_before_target_outcomes"},
        "input_schema": {"type": "string", "pattern": "^[a-z0-9-]+\\.schema\\.json$"},
        "required_families": {"$ref": "#/$defs/idList"},
        "primary_estimand": {"type": "string", "minLength": 1},
        "uncertainty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "critical_value", "confidence_level"],
          "properties": {
            "method": {"enum": ["independent_pair_normal_lcb", "trace_family_cluster_paired_brier_normal_lcb", "max_case_reviewer_cluster_normal_lcb"]},
            "critical_value": {"const": 1.96},
            "confidence_level": {"const": 0.95}
          }
        },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minimum_observations_per_family": {"type": "integer", "minimum": 1},
            "minimum_trace_families_per_family": {"type": "integer", "minimum": 2},
            "minimum_observations_per_arm_per_family": {"type": "integer", "minimum": 1},
            "minimum_cases_per_family": {"type": "integer", "minimum": 1},
            "minimum_reviewers_per_arm_per_family": {"type": "integer", "minimum": 1},
            "minimum_selective_margin": {"type": "number"},
            "selective_margin_lcb_strictly_above": {"type": "number"},
            "minimum_control_accuracy": {"type": "number", "minimum": 0, "maximum": 1},
            "minimum_mean_brier_improvement": {"type": "number"},
            "brier_improvement_lcb_strictly_above": {"type": "number"},
            "maximum_typed_brier_loss": {"type": "number", "minimum": 0},
            "maximum_typed_ece": {"type": "number", "minimum": 0, "maximum": 1},
            "minimum_typed_minus_degraded_concordance": {"type": "number"},
            "concordance_difference_lcb_strictly_above": {"type": "number"},
            "maximum_typed_false_certainty": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "integrity_rules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reset_policy", "split_policy", "banned_view_key_tokens", "reference_join_policy", "required_design_object_bindings"],
          "properties": {
            "reset_policy": {"enum": ["reset_before_each_presentation", "independent_randomized_presentation"]},
            "split_policy": {"enum": ["held_out_base_items", "disjoint_trace_families", "held_out_cases_balanced_across_arms"]},
            "banned_view_key_tokens": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "reference_join_policy": {"enum": ["after_response_lock", "after_prediction_lock", "after_review_lock"]},
            "required_design_object_bindings": {"$ref": "#/$defs/idList"},
            "feature_allowlist": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/id"}
            },
            "matched_case_coverage_required": {"type": "boolean"}
          }
        },
        "aggregation_rule": {"const": "familywise_noncompensatory_vector"}
      }
    }
  }
}
