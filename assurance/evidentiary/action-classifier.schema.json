{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/action-classifier.schema.json",
  "title": "Prospective action classifier",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "classifier_id", "classifier_version", "frozen_at", "classification_fields", "rules", "no_match_rule", "multiple_match_rule"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "classifier_id": {"type": "string"},
    "classifier_version": {"type": "string"},
    "frozen_at": {"type": "string", "format": "date-time"},
    "classification_fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "rules": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["rule_id", "priority", "all", "result_action_class"],
        "properties": {
          "rule_id": {"type": "string"}, "priority": {"type": "integer", "minimum": 0},
          "all": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["field", "operator", "value"],
              "properties": {"field": {"type": "string"}, "operator": {"const": "equals"}, "value": {}}
            }
          },
          "result_action_class": {"type": "string"}
        }
      }
    },
    "no_match_rule": {"const": "reject_unclassified_action"},
    "multiple_match_rule": {"const": "select_lowest_priority_number_and_reject_ties"}
  }
}
