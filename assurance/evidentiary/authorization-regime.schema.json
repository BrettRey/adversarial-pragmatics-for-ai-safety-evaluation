{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/authorization-regime.schema.json",
  "title": "Stipulated calibration authorization regime",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "regime_id", "regime_version", "effective_from", "effective_until", "status", "not_a_legal_conclusion", "sources", "answerability_requirement", "object_forum_requirement"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "regime_id": {"type": "string"}, "regime_version": {"type": "string"},
    "effective_from": {"type": "string", "format": "date-time"},
    "effective_until": {"type": ["string", "null"], "format": "date-time"},
    "status": {"const": "stipulated_for_calibration_only"},
    "not_a_legal_conclusion": {"const": true},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "object", "minProperties": 5}},
    "answerability_requirement": {"type": "object", "required": ["identity", "duty", "reachability"]},
    "object_forum_requirement": {"type": "object", "required": ["access", "competence", "independence", "remedy"]}
  }
}
