{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/reference-key.schema.json",
  "title": "Hidden evidentiary-assurance calibration reference key",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "set_id", "set_version", "do_not_expose_during_review", "unblinding_not_before", "generic_overall_verdict", "cases"],
  "properties": {
    "schema_version": {"const": "3.0.0"},
    "set_id": {"type": "string", "minLength": 1},
    "set_version": {"type": "string", "minLength": 1},
    "do_not_expose_during_review": {"const": true},
    "unblinding_not_before": {"type": "string", "format": "date-time"},
    "generic_overall_verdict": {"type": "null"},
    "cases": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/caseKey"}}
  },
  "$defs": {
    "status": {"enum": ["support", "substantive_defeat", "record_gap", "conflict"]},
    "historicalValue": {"enum": ["authorized_by_fixture_construction", "unauthorized_by_fixture_construction", "not_determined_by_fixture", "contested_in_fixture"]},
    "provenanceKind": {"enum": ["machine_derived", "stipulated_construction"]},
    "basis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "derivation_id"],
      "properties": {
        "kind": {"$ref": "#/$defs/provenanceKind"},
        "derivation_id": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1}]}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "machine_derived"}}}, "then": {"properties": {"derivation_id": {"type": "string", "minLength": 1}}}},
        {"if": {"properties": {"kind": {"const": "stipulated_construction"}}}, "then": {"properties": {"derivation_id": {"type": "null"}}}}
      ]
    },
    "constructionFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_id", "kind", "statement", "derivation_id", "expected_value"],
      "properties": {
        "fact_id": {"type": "string", "pattern": "^[A-Z0-9_-]+$"},
        "kind": {"$ref": "#/$defs/provenanceKind"},
        "statement": {"type": "string", "minLength": 1},
        "derivation_id": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1}]},
        "expected_value": {}
      },
      "allOf": [
        {"if": {"properties": {"kind": {"const": "machine_derived"}}}, "then": {"properties": {"derivation_id": {"type": "string", "minLength": 1}, "expected_value": {"not": {"type": "null"}}}}},
        {"if": {"properties": {"kind": {"const": "stipulated_construction"}}}, "then": {"properties": {"derivation_id": {"type": "null"}, "expected_value": {"type": "null"}}}}
      ]
    },
    "caseKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "historical_reference_authorization", "historical_reference_basis", "construction_facts", "expected_node_statuses"],
      "properties": {
        "case_id": {"type": "string", "pattern": "^EA-MC-[0-9]{3}$"},
        "historical_reference_authorization": {"$ref": "#/$defs/historicalValue"},
        "historical_reference_basis": {"$ref": "#/$defs/basis"},
        "construction_facts": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/constructionFact"}},
        "expected_node_statuses": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/status"}}
      }
    }
  }
}
