{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/record-set.schema.json",
  "title": "Harmless synthetic action-record set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_set_id",
    "case_id",
    "action",
    "record_inventory",
    "records",
    "privacy_and_burden"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0.0"
    },
    "record_set_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string",
      "pattern": "^EA-MC-[0-9]{3}$"
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "operation_type",
        "occurred_at",
        "boundary",
        "classification_fields",
        "observable_action"
      ],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "operation_type": {
          "enum": [
            "single_action",
            "bounded_trajectory"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "boundary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end",
            "stopping_condition"
          ],
          "properties": {
            "start": {
              "type": "string"
            },
            "end": {
              "type": "string"
            },
            "stopping_condition": {
              "type": "string"
            }
          }
        },
        "classification_fields": {
          "type": "object",
          "minProperties": 5
        },
        "observable_action": {
          "type": "object",
          "minProperties": 1
        }
      }
    },
    "record_inventory": {
      "description": "Inventory of prospectively required evidence slots. An evidence slot is a review function, not a concrete record type: for example, an authoritative registry may occupy the delegation-instrument slot by establishing that no instrument exists.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/inventoryItem"
      }
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "privacy_and_burden": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "data_classification",
        "collection_purpose",
        "minimization_measure",
        "retention_rule",
        "protected_material_route",
        "review_minutes_estimate",
        "reviewer_burden_level",
        "privacy_risks",
        "security_risks",
        "tolerance_status"
      ],
      "properties": {
        "data_classification": {
          "type": "string"
        },
        "collection_purpose": {
          "type": "string"
        },
        "minimization_measure": {
          "type": "string"
        },
        "retention_rule": {
          "type": "string"
        },
        "protected_material_route": {
          "type": "string"
        },
        "review_minutes_estimate": {
          "type": "integer",
          "minimum": 0
        },
        "reviewer_burden_level": {
          "enum": [
            "low",
            "moderate",
            "high"
          ]
        },
        "privacy_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "security_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tolerance_status": {
          "enum": [
            "within_declared_tolerance",
            "exceeds_declared_tolerance"
          ]
        }
      }
    }
  },
  "$defs": {
    "inventoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_slot",
        "state",
        "record_ids",
        "search_scope"
      ],
      "properties": {
        "evidence_slot": {
          "type": "string",
          "description": "Prospectively declared module slot served, contested, or shown missing by this inventory entry."
        },
        "state": {
          "enum": [
            "present",
            "missing_after_declared_search",
            "contested"
          ]
        },
        "record_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "search_scope": {
          "type": "string"
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_id",
        "record_type",
        "title",
        "content",
        "provenance",
        "authenticity_evidence",
        "integrity_evidence",
        "access_class",
        "evidence_origin"
      ],
      "properties": {
        "record_id": {
          "type": "string"
        },
        "record_type": {
          "type": "string",
          "description": "Concrete type of the visible record; it need not have the same label as the evidence slot it bears on."
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "object"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "captured_at",
            "custodian"
          ],
          "properties": {
            "source": {
              "type": "string"
            },
            "captured_at": {
              "type": "string",
              "format": "date-time"
            },
            "custodian": {
              "type": "string"
            }
          }
        },
        "authenticity_evidence": {
          "type": "object",
          "minProperties": 1
        },
        "integrity_evidence": {
          "type": "object",
          "minProperties": 1
        },
        "access_class": {
          "enum": [
            "reviewer_visible",
            "protected_review",
            "restricted"
          ]
        },
        "evidence_origin": {
          "enum": [
            "action_contemporaneous",
            "review_obtained",
            "external_later"
          ],
          "description": "Which evidence set the record belongs to. J_R assesses the contemporaneous set; later external material can bear on substantive nodes without curing a J_R gap."
        }
      }
    }
  }
}
