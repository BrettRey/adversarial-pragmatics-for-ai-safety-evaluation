{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/evidence-bundle.schema.json",
  "title": "Reviewer-visible evidentiary-assurance case bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "case_id",
    "claim_graph_version",
    "declared_use_id",
    "map_binding",
    "classifier_binding",
    "regime_binding",
    "review_timing",
    "target_binding"
  ],
  "properties": {
    "schema_version": {
      "const": "3.0.0"
    },
    "bundle_id": {
      "type": "string",
      "pattern": "^EA-EB-[0-9]{3}$"
    },
    "case_id": {
      "type": "string",
      "pattern": "^EA-MC-[0-9]{3}$"
    },
    "claim_graph_version": {
      "const": "3.0.0"
    },
    "declared_use_id": {
      "type": "string",
      "minLength": 1
    },
    "map_binding": {
      "$ref": "#/$defs/contentBinding"
    },
    "classifier_binding": {
      "$ref": "#/$defs/contentBinding"
    },
    "regime_binding": {
      "$ref": "#/$defs/contentBinding"
    },
    "review_timing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_opened_at",
        "reference_key_unblinding_not_before"
      ],
      "properties": {
        "review_opened_at": {
          "type": "string",
          "format": "date-time"
        },
        "reference_key_unblinding_not_before": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "target_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "action_sha256",
        "asserted_action_class",
        "classification_rule_id"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^records/EA-MC-[0-9]{3}-records\\.json$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "action_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "asserted_action_class": {
          "type": "string"
        },
        "classification_rule_id": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "contentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "path",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  }
}
