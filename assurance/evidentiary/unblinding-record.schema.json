{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/evidentiary-assurance/unblinding-record.schema.json",
  "title": "Evidentiary-assurance hidden-key opening record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "key_binding",
    "unblinding_not_before",
    "opened_at",
    "opened_by",
    "opening_method"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "key_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "const": "hidden/reference-keys.json"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "unblinding_not_before": {
      "type": "string",
      "format": "date-time"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "opened_by": {
      "type": "string",
      "minLength": 1
    },
    "opening_method": {
      "type": "string",
      "minLength": 1
    }
  }
}
